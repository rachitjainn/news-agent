APP_ENV=development
APP_NAME=news-agent
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/news_agent
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=news-jobs

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=app-password
SMTP_USE_TLS=true
FROM_EMAIL=news-agent@example.com

POLL_INTERVAL_MINUTES=5
ALERT_DEBOUNCE_MINUTES=15
MAX_ALERT_ARTICLES=8
MAX_FETCH_ARTICLES=50

GNEWS_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_TOP_CANDIDATES=10
ENABLE_LLM=true
ENABLE_DIGEST_FALLBACK=true

WORKER_HEARTBEAT_TTL_SECONDS=180
SCHEDULER_HEARTBEAT_TTL_SECONDS=180
